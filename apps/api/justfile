set dotenv-load

# Run FastAPI dev server
dev:
    INNGEST_DEV=1 uv run fastapi dev main.py --port 8000

# Run Inngest dev server
inngest:
    npx inngest-cli@latest dev

# Run both FastAPI + Inngest dev servers
dev-all:
    just dev & just inngest & wait

# Format code
fmt:
    uv run ruff format .

# Lint code
lint:
    uv run ruff check .

# Lint and fix
lint-fix:
    uv run ruff check --fix src

# Run alembic migration
migrate:
    uv run alembic upgrade head

# Create a new alembic migration
migration name:
    uv run alembic revision --autogenerate -m "{{name}}"

# Sync dependencies
sync:
    uv sync
